# docker-compose(app 서비스)에서 사용하는 환경변수 템플릿.
# 이 파일을 .env.docker 로 복사한 뒤 실제 값을 채워 넣으세요. (.env.docker 는 git에 커밋되지 않음)
#   cp .env.docker.example .env.docker

### Database (Supabase) ###
# Supabase 대시보드 > Project Settings > Database > Connection string(JDBC) 참고.
# 컨테이너 -> 외부 Supabase 접속이므로 Connection Pooler 호스트 사용 권장.
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=<your-db-password>

### OAuth (미설정 시 application.yml 의 기본값 사용) ###
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

### 서비스 URL (배포 도메인에 맞게 변경) ###
SERVICE_URL_WEB=http://localhost:5173
SERVICE_URL_SERVER=http://localhost:8080
